%% view: VIEW-INTERACTION-FLOW (interaction-flow)
N_ACT_BARISTA(("Barista")):::actor
N_ACT_FLEET_OPERATOR(("Fleet Operator")):::actor
N_DO_COFFEE_OTA_PLAN[("OTA Rollout Plan")]:::data_object
N_DO_COFFEE_TELEMETRY_EVENT[("Telemetry Event")]:::data_object
N_FLOW_COFFEE_OTA_ROLLOUT{"OTA Rollout Interaction Flow"}:::flow
N_FLOW_COFFEE_TELEMETRY_INGEST{"Telemetry Ingestion Interaction Flow"}:::flow
N_FLOW_COFFEE_OTA_ROLLOUT__execute_update>"Execute signed OTA update on edge devices"]:::flow_step
N_FLOW_COFFEE_OTA_ROLLOUT__operator_schedules_rollout>"Fleet operator schedules OTA campaign"]:::flow_step
N_FLOW_COFFEE_OTA_ROLLOUT__plan_campaign>"Build rollout cohorts and policy checks"]:::flow_step
N_FLOW_COFFEE_OTA_ROLLOUT__report_outcome>"Emit rollout status and observability summary"]:::flow_step
N_FLOW_COFFEE_TELEMETRY_INGEST__capture_machine_telemetry>"Barista machine activity produces telemetry events"]:::flow_step
N_FLOW_COFFEE_TELEMETRY_INGEST__collect_and_send_telemetry>"Collect and send telemetry payloads to cloud ingest"]:::flow_step
N_FLOW_COFFEE_TELEMETRY_INGEST__ingest_telemetry>"Validate and ingest telemetry records"]:::flow_step
N_FLOW_COFFEE_TELEMETRY_INGEST__publish_fleet_observability>"Publish fleet observability and audit summaries"]:::flow_step
N_FU_FLEET_INGESTION_API["Fleet Ingestion API"]:::functional_unit
N_FU_FLEET_OBSERVABILITY_REPORTING["Fleet Observability Reporting"]:::functional_unit
N_FU_MACHINE_TELEMETRY_COLLECTION["Machine Telemetry Collection"]:::functional_unit
N_FU_OTA_UPDATE_AGENT["OTA Update Agent"]:::functional_unit
N_FU_UPDATE_CAMPAIGN_ORCHESTRATION["Update Campaign Orchestration"]:::functional_unit
N_IF_COFFEE_OTA_COMMAND[/"OTA Command Interface"/]:::interface
N_IF_COFFEE_TELEMETRY_INGEST[/"Telemetry Ingestion Interface"/]:::interface
N_FLOW_COFFEE_OTA_ROLLOUT --> N_FLOW_COFFEE_OTA_ROLLOUT__operator_schedules_rollout
N_FLOW_COFFEE_OTA_ROLLOUT__execute_update -->|async| N_FLOW_COFFEE_OTA_ROLLOUT__report_outcome
N_FLOW_COFFEE_OTA_ROLLOUT__execute_update -->|error| N_FLOW_COFFEE_OTA_ROLLOUT__report_outcome
N_FLOW_COFFEE_OTA_ROLLOUT__execute_update -->|ref| N_FU_OTA_UPDATE_AGENT
N_FLOW_COFFEE_OTA_ROLLOUT__operator_schedules_rollout -->|ref| N_ACT_FLEET_OPERATOR
N_FLOW_COFFEE_OTA_ROLLOUT__operator_schedules_rollout --> N_FLOW_COFFEE_OTA_ROLLOUT__plan_campaign
N_FLOW_COFFEE_OTA_ROLLOUT__plan_campaign --> N_FLOW_COFFEE_OTA_ROLLOUT__execute_update
N_FLOW_COFFEE_OTA_ROLLOUT__plan_campaign -->|ref| N_FU_UPDATE_CAMPAIGN_ORCHESTRATION
N_FLOW_COFFEE_OTA_ROLLOUT__report_outcome -->|ref| N_FU_FLEET_OBSERVABILITY_REPORTING
N_FLOW_COFFEE_TELEMETRY_INGEST --> N_FLOW_COFFEE_TELEMETRY_INGEST__capture_machine_telemetry
N_FLOW_COFFEE_TELEMETRY_INGEST__capture_machine_telemetry -->|ref| N_ACT_BARISTA
N_FLOW_COFFEE_TELEMETRY_INGEST__capture_machine_telemetry --> N_FLOW_COFFEE_TELEMETRY_INGEST__collect_and_send_telemetry
N_FLOW_COFFEE_TELEMETRY_INGEST__collect_and_send_telemetry --> N_FLOW_COFFEE_TELEMETRY_INGEST__ingest_telemetry
N_FLOW_COFFEE_TELEMETRY_INGEST__collect_and_send_telemetry -->|ref| N_FU_MACHINE_TELEMETRY_COLLECTION
N_FLOW_COFFEE_TELEMETRY_INGEST__ingest_telemetry --> N_FLOW_COFFEE_TELEMETRY_INGEST__publish_fleet_observability
N_FLOW_COFFEE_TELEMETRY_INGEST__ingest_telemetry -->|ref| N_FU_FLEET_INGESTION_API
N_FLOW_COFFEE_TELEMETRY_INGEST__publish_fleet_observability -->|ref| N_FU_FLEET_OBSERVABILITY_REPORTING
N_FU_FLEET_INGESTION_API -->|contains| N_IF_COFFEE_TELEMETRY_INGEST
N_FU_MACHINE_TELEMETRY_COLLECTION -->|contains| N_DO_COFFEE_TELEMETRY_EVENT
N_FU_MACHINE_TELEMETRY_COLLECTION -->|writes| N_DO_COFFEE_TELEMETRY_EVENT
N_FU_MACHINE_TELEMETRY_COLLECTION -->|calls| N_IF_COFFEE_TELEMETRY_INGEST
N_FU_OTA_UPDATE_AGENT -->|reads| N_DO_COFFEE_OTA_PLAN
N_FU_UPDATE_CAMPAIGN_ORCHESTRATION -->|contains| N_DO_COFFEE_OTA_PLAN
N_FU_UPDATE_CAMPAIGN_ORCHESTRATION -->|writes| N_DO_COFFEE_OTA_PLAN
N_FU_UPDATE_CAMPAIGN_ORCHESTRATION -->|calls| N_IF_COFFEE_OTA_COMMAND
N_FU_UPDATE_CAMPAIGN_ORCHESTRATION -->|contains| N_IF_COFFEE_OTA_COMMAND
