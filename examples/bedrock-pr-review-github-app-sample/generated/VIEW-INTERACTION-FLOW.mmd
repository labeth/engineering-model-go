flowchart LR
%% view: VIEW-INTERACTION-FLOW (interaction-flow)
N_ACT_DEVELOPER(("Developer")):::actor
N_ACT_SECURITY_ENGINEER(("Security Engineer")):::actor
N_DO_BEDROCK_PR_CONTEXT[("Pull Request Context")]:::data_object
N_DO_BEDROCK_REVIEW_FINDINGS[("Review Findings")]:::data_object
N_FLOW_BEDROCK_POLICY_TUNING{"Security Policy Tuning Flow"}:::flow
N_FLOW_BEDROCK_PR_REVIEW{"PR Review Interaction Flow"}:::flow
N_FLOW_BEDROCK_POLICY_TUNING__orchestrate_policy_validation>"Orchestrate dry-run review validation with policy outputs"]:::flow_step
N_FLOW_BEDROCK_POLICY_TUNING__publish_policy_validation>"Publish policy validation findings to repository maintainers"]:::flow_step
N_FLOW_BEDROCK_POLICY_TUNING__run_policy_checks>"Execute deterministic policy checks on candidate rules"]:::flow_step
N_FLOW_BEDROCK_POLICY_TUNING__update_policy_rules>"Security engineer updates review policy rules"]:::flow_step
N_FLOW_BEDROCK_PR_REVIEW__assemble_context>"Build bounded review context"]:::flow_step
N_FLOW_BEDROCK_PR_REVIEW__orchestrate_review>"Run AI + policy checks and prepare findings"]:::flow_step
N_FLOW_BEDROCK_PR_REVIEW__publish_review>"Publish findings to GitHub check run"]:::flow_step
N_FLOW_BEDROCK_PR_REVIEW__receive_webhook>"Developer pushes PR updates that trigger webhook processing"]:::flow_step
N_FU_POLICY_CHECKS["Policy Checks"]:::functional_unit
N_FU_PR_CONTEXT_ASSEMBLY["PR Context Assembly"]:::functional_unit
N_FU_REVIEW_ORCHESTRATION["Review Orchestration"]:::functional_unit
N_FU_REVIEW_PUBLICATION["Review Publication"]:::functional_unit
N_IF_BEDROCK_REVIEW_PUBLISH_API[/"Review Publish API"/]:::interface
N_FLOW_BEDROCK_POLICY_TUNING --> N_FLOW_BEDROCK_POLICY_TUNING__update_policy_rules
N_FLOW_BEDROCK_POLICY_TUNING__orchestrate_policy_validation --> N_FLOW_BEDROCK_POLICY_TUNING__publish_policy_validation
N_FLOW_BEDROCK_POLICY_TUNING__orchestrate_policy_validation -->|ref| N_FU_REVIEW_ORCHESTRATION
N_FLOW_BEDROCK_POLICY_TUNING__publish_policy_validation -->|ref| N_FU_REVIEW_PUBLICATION
N_FLOW_BEDROCK_POLICY_TUNING__run_policy_checks --> N_FLOW_BEDROCK_POLICY_TUNING__orchestrate_policy_validation
N_FLOW_BEDROCK_POLICY_TUNING__run_policy_checks -->|ref| N_FU_POLICY_CHECKS
N_FLOW_BEDROCK_POLICY_TUNING__update_policy_rules -->|ref| N_ACT_SECURITY_ENGINEER
N_FLOW_BEDROCK_POLICY_TUNING__update_policy_rules --> N_FLOW_BEDROCK_POLICY_TUNING__run_policy_checks
N_FLOW_BEDROCK_PR_REVIEW --> N_FLOW_BEDROCK_PR_REVIEW__receive_webhook
N_FLOW_BEDROCK_PR_REVIEW__assemble_context --> N_FLOW_BEDROCK_PR_REVIEW__orchestrate_review
N_FLOW_BEDROCK_PR_REVIEW__assemble_context -->|ref| N_FU_PR_CONTEXT_ASSEMBLY
N_FLOW_BEDROCK_PR_REVIEW__orchestrate_review -->|async| N_FLOW_BEDROCK_PR_REVIEW__publish_review
N_FLOW_BEDROCK_PR_REVIEW__orchestrate_review -->|error| N_FLOW_BEDROCK_PR_REVIEW__publish_review
N_FLOW_BEDROCK_PR_REVIEW__orchestrate_review -->|ref| N_FU_REVIEW_ORCHESTRATION
N_FLOW_BEDROCK_PR_REVIEW__publish_review -->|ref| N_FU_REVIEW_PUBLICATION
N_FLOW_BEDROCK_PR_REVIEW__receive_webhook -->|ref| N_ACT_DEVELOPER
N_FLOW_BEDROCK_PR_REVIEW__receive_webhook --> N_FLOW_BEDROCK_PR_REVIEW__assemble_context
N_FU_PR_CONTEXT_ASSEMBLY -->|writes| N_DO_BEDROCK_PR_CONTEXT
N_FU_REVIEW_ORCHESTRATION -->|contains| N_DO_BEDROCK_PR_CONTEXT
N_FU_REVIEW_ORCHESTRATION -->|reads| N_DO_BEDROCK_PR_CONTEXT
N_FU_REVIEW_ORCHESTRATION -->|writes| N_DO_BEDROCK_REVIEW_FINDINGS
N_FU_REVIEW_PUBLICATION -->|contains| N_DO_BEDROCK_REVIEW_FINDINGS
N_FU_REVIEW_PUBLICATION -->|reads| N_DO_BEDROCK_REVIEW_FINDINGS
N_FU_REVIEW_PUBLICATION -->|calls| N_IF_BEDROCK_REVIEW_PUBLISH_API
N_FU_REVIEW_PUBLICATION -->|contains| N_IF_BEDROCK_REVIEW_PUBLISH_API
